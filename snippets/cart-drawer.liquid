<div class="cart-overlay"></div>

<aside class="cart-drawer" aria-hidden="true">
  <div class="cart-drawer__header">
    <h2>Your basket</h2>
    <button type="button" class="cart-drawer__clear">Clear</button>
  </div>

  <div class="cart-drawer__items"></div>

  <div class="cart-drawer__footer">
    <div class="cart-total">
      <p class="cart-items-row">
        <span class="cart-total-items">0</span>
      </p>
      <span class="cart-drawer__subtotal-price">£0.00</span>
    </div>
    <div class="cart-points-message"></div>
    <a href="/checkout" class="cart-checkout-button">Checkout now</a>
  </div>
</aside>
